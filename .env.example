# Local LLM (Ollama)
RD_USE_LOCAL_LLM=true
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=qwen3:8b
LOCAL_LLM_TIMEOUT=60

# Reality Debugger tuning
RD_CACHE_SIZE=120
RD_CONTEXT_WINDOW=3
RD_TYPING_EFFECT=false
RD_TYPING_DELAY=0.01
RD_UI_TRANSITIONS=true
RD_UI_TRANSITION_DELAY=0.35
RD_DEV_MODE=false
