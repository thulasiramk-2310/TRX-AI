# Local LLM (Ollama)
RD_USE_LOCAL_LLM=true
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=qwen3:8b
LOCAL_LLM_TIMEOUT=60

# Reality Debugger tuning
RD_CACHE_SIZE=120
RD_CACHE_TTL_SECONDS=300
RD_DEBUG_CACHE=false
RD_CONTEXT_WINDOW=3
RD_TYPING_EFFECT=false
RD_TYPING_DELAY=0.01
RD_UI_TRANSITIONS=true
RD_UI_TRANSITION_DELAY=0.35
RD_DEV_MODE=false
RD_ASSISTANT_MODE=auto

# Graph transport (code-review-graph): local | remote | hybrid
RD_GRAPH_TRANSPORT=local
# Remote MCP HTTP base URL (used when RD_GRAPH_TRANSPORT=remote|hybrid)
RD_GRAPH_REMOTE_URL=http://localhost:8080
# Optional bearer token for remote MCP
RD_GRAPH_REMOTE_API_KEY=
# Circuit breaker tuning for graph client
RD_GRAPH_CB_FAIL_THRESHOLD=3
RD_GRAPH_CB_OPEN_SECONDS=15
RD_GRAPH_CACHE_TTL_SECONDS=300
RD_STRUCTURED_LOGS=true
# Optional semantic intent backend
# pip install sentence-transformers
